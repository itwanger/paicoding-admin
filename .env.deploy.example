# 部署服务器 IP 或域名
DEPLOY_SERVER_HOST=127.0.0.1

# 部署服务器登录用户，默认 admin
DEPLOY_SERVER_USER=admin

# SSH 私钥路径；如果机器已配置免密，可留空
DEPLOY_SERVER_KEY=/Users/yourname/.ssh/id_rsa

# 前端构建产物上传目录
DEPLOY_TARGET_DIR=/home/admin

# 可选：自定义构建命令，默认 npm run build:pro
# DEPLOY_BUILD_CMD=npm run build:pro

# 可选：部署完成后健康检查地址
# DEPLOY_HEALTHCHECK_URL=https://example.com/admin
